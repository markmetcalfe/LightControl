{
    "node-lirc": {
	    "commands": {
    		"lircd": "lircd",
    		"irrecord": "irrecord",
    		"irsend": "irsend",
    		"unbuffer": "unbuffer"
        },
	    "lirc_driver": "default",
    	"lirc_conf": "/etc/lirc/lircd.conf",
        "lirc_pid": "/var/run/lirc/lircd.pid",
	    "device": "/dev/lirc0",
        "tmp_dir": "tmp/"
    },
    "remote": "led_lightbulb",
    "commands": {
        "On": "power_on",
        "Off": "power_off",
        "Up": "brightness_up",
        "Down": "brightness_down",
        "White": "color_white",
        "Red": "color_red",
        "Orange": "color_orange",
        "Amber": "color_amber",
        "Yellow": "color_yellow",
        "Green": "color_green",
        "Aqua": "color_aqua",
        "Light Blue": "color_lightblue",
        "Blue": "color_blue",
        "Purple": "color_purple",
        "Pink": "color_pink",
        "Flash": "change_flash",
        "Strobe": "change_strobe",
        "Fade": "change_fade",
        "Smooth": "change_smooth"
    }
}